# ══════════════════════════════════════════════════════════════════════════════
# LBS Intelligence System — Environment Variables
# Copy this file to .env and fill in real values. Never commit .env to git.
# ══════════════════════════════════════════════════════════════════════════════

# ── Google (Shared Service Account) ──────────────────────────────────────────
# Path to the service account JSON key file downloaded from Google Cloud Console
# Used by both GA4 and Search Console
GOOGLE_SERVICE_ACCOUNT_JSON=credentials/google_service_account.json

# ── Google Analytics 4 ────────────────────────────────────────────────────────
# Found in GA4 Admin → Property Settings → Property ID
GA4_PROPERTY_ID=123456789

# ── Google Search Console ─────────────────────────────────────────────────────
# Must match exactly how the property appears in GSC (including trailing slash)
GSC_SITE_URL=https://lightbulbsurplus.com/

# ── Google Ads ────────────────────────────────────────────────────────────────
# Developer token: Google Ads → Tools → API Center
# Client ID/Secret: Google Cloud Console → OAuth 2.0 credentials (Desktop app)
# Refresh token: generated via one-time OAuth flow (see setup docs)
# Customer ID: 10-digit number in top-right of Google Ads (no dashes)
GOOGLE_ADS_DEVELOPER_TOKEN=your_developer_token_here
GOOGLE_ADS_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_ADS_CLIENT_SECRET=your_client_secret_here
GOOGLE_ADS_REFRESH_TOKEN=your_refresh_token_here
GOOGLE_ADS_CUSTOMER_ID=1234567890

# ── BigCommerce ───────────────────────────────────────────────────────────────
# API Account: BC Admin → Advanced Settings → API Accounts → Create API Account
# Required scopes: Orders (read), Products (read), Catalog (read)
# Store hash is in the credentials file BC provides on account creation
BC_STORE_HASH=your_store_hash_here
BC_ACCESS_TOKEN=your_access_token_here
BC_CLIENT_ID=your_client_id_here

# ── Supabase ──────────────────────────────────────────────────────────────────
# Found in Supabase project dashboard → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
# Direct connection string for psycopg2 bulk inserts (Settings → Database → Connection string)
DATABASE_URL=postgresql://postgres:your_password@db.your-project-ref.supabase.co:5432/postgres

# ── Anthropic ─────────────────────────────────────────────────────────────────
# console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-your_key_here
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Report Settings ───────────────────────────────────────────────────────────
REPORT_LOOKBACK_DAYS=7
# Minimum product views in a week before including in analysis (filters noise)
MIN_PRODUCT_VIEWS_THRESHOLD=50
# Minimum brand-level views before including in brand analysis
MIN_BRAND_VIEWS_THRESHOLD=200
